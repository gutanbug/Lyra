{
  "name": "lyra",
  "description": "Lyra - Desktop App",
  "version": "1.0.0",
  "private": false,
  "main": "dist-electron/main.js",
  "homepage": "./",
  "dependencies": {
    "@types/node": "^12.0.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^16.9.8",
    "@types/react-router-dom": "^5.1.5",
    "@types/styled-components": "^5.1.7",
    "axios": "^1.13.6",
    "electron-store": "^8.2.0",
    "immer": "^8.0.0",
    "lucide-react": "^0.577.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-helmet-async": "^1.0.6",
    "react-router-dom": "^5.2.0",
    "styled-components": "^5.2.1",
    "typescript": "^4.1.3",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "prebuild": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts test --watchAll=false",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "postbuild": "test -d ../backend/app/client && cp -r build/* ../backend/app/client || true",
    "test": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts test",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:setup-dev": "bash scripts/setup-electron-dev.sh",
    "electron:dev": "pnpm build:electron && pnpm electron:setup-dev && concurrently \"BROWSER=none pnpm start\" \"wait-on http://localhost:3000 && NODE_ENV=development electron .\"",
    "electron:build": "pnpm build:electron && pnpm build && electron-builder",
    "electron:start": "pnpm build:electron && pnpm build && electron ."
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "@types/jest": "^26.0.15",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^25.1.8",
    "react-refresh": "^0.18.0",
    "react-scripts": "4.0.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "extends": null,
    "appId": "com.lyra.app",
    "productName": "Lyra",
    "files": [
      "build/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build-resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "maintainer": "Lyra <gutanbug53@gmail.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "electron"
    ],
    "overrides": {
      "@babel/core": "^7.24.0"
    }
  }
}

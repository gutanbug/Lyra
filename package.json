{
  "name": "lyra",
  "description": "Lyra - Desktop App",
  "version": "1.4.1",
  "private": false,
  "main": "dist-electron/main.js",
  "homepage": "./",
  "dependencies": {
    "@atlaskit/adf-schema": "^52.2.4",
    "@atlaskit/adf-utils": "^19.27.8",
    "@atlaskit/editor-common": "^112.2.3",
    "@atlaskit/editor-core": "^217.1.3",
    "@atlaskit/mention": "^24.5.3",
    "@atlaskit/renderer": "^120.5.10",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@types/node": "^12.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.34",
    "axios": "^1.13.6",
    "electron-store": "^8.2.0",
    "immer": "^8.0.0",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^1.0.6",
    "react-intl": "^5.25.1",
    "react-router-dom": "^5.2.0",
    "styled-components": "^5.2.1",
    "typescript": "^4.1.3",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "postinstall": "node scripts/patch-atlaskit.js",
    "start": "vite",
    "prebuild": "vitest run",
    "build": "tsc --noEmit && vite build",
    "postbuild": "test -d ../backend/app/client && cp -r build/* ../backend/app/client || true",
    "preview": "vite preview",
    "test": "vitest",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron:dev": "pnpm build:electron && concurrently \"BROWSER=none pnpm start\" \"wait-on http://localhost:5173 && NODE_ENV=development electron .\"",
    "electron:build": "pnpm build:electron && pnpm build && electron-builder",
    "electron:start": "pnpm build:electron && pnpm build && electron ."
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^12.1.10",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.0",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^25.1.8",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "extends": null,
    "appId": "com.lyra.app",
    "productName": "Lyra",
    "files": [
      "build/**/*",
      "dist-electron/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build-resources"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build-resources/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build-resources/icon.png",
      "maintainer": "Lyra <gutanbug53@gmail.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ],
    "ignoredBuiltDependencies": [
      "electron"
    ],
    "overrides": {
      "@babel/core": "^7.24.0",
      "@types/react": "^18.3.28",
      "@types/react-dom": "^18.3.7",
      "relay-runtime": "20.1.1",
      "@loomhq/lens": "12.14.0",
      "react-intl-next": "npm:react-intl@^5.25.1"
    }
  }
}
